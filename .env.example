MONGO_URI=mongodb://127.0.0.1:27017/governance
JWT_SECRET=change-me-to-a-long-random-string
PORT=4000
# Python governance engine we proxy bot join/stop to
PYTHON_ENGINE_URL=http://localhost:8000

# --- KMS-wrapped keys (envelope encryption) - OPTIONAL, off by default ---
# Leave KMS_KEY_ID unset to use raw local AES-256 data keys (default, no AWS dependency).
# Set it to a KMS key id/ARN to wrap each meeting's data key under your KMS key; the
# plaintext data key is then never persisted (only the wrapped ciphertext blob is).
# KMS_KEY_ID=arn:aws:kms:us-east-1:111122223333:key/abcd-...
# AWS_REGION defaults to us-east-1 when unset (also used elsewhere for AWS clients).
# AWS_REGION=us-east-1
